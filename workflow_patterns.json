      {"step_id":"step_07","algorithm":"native:clip","parameters":{"INPUT":"outputs/SteepTerrain_Filtered.shp","OVERLAY":"outputs/Boundary.shp"},"input_files":["outputs/SteepTerrain_Filtered.shp","outputs/Boundary.shp"],"output_file":"outputs/SteepTerrain_Final.shp","script_filename":"step_07_clip_to_boundary.py"}
    ]
  }
