[
  {
    "step_id": "step_01",
    "algorithm": "native:extractbyattribute",
    "parameters": {
      "INPUT": "data/gadm41_IND_1.shp",
      "FIELD": "NAME_1",
      "OPERATOR": 0,
      "VALUE": "Kerala"
    },
    "input_files": [
      "data/gadm41_IND_1.shp"
    ],
    "output_file": "outputs/kerala_boundary.shp",
    "script_filename": "step_01_extract_kerala_boundary.py"
  },
  {
    "step_id": "step_02",
    "algorithm": "gdal:cliprasterbymasklayer",
    "parameters": {
      "INPUT": "data/kerala_dem.tif",
      "MASK": "outputs/kerala_boundary.shp",
      "CROP_TO_CUTLINE": true,
      "KEEP_RESOLUTION": true
    },
    "input_files": [
      "data/kerala_dem.tif",
      "outputs/kerala_boundary.shp"
    ],
    "output_file": "outputs/kerala_dem_clipped.tif",
    "script_filename": "step_02_clip_dem.py"
  },
  {
    "step_id": "step_03",
    "algorithm": "gdal:rastercalculator",
    "parameters": {
      "INPUT_A": "outputs/kerala_dem_clipped.tif",
      "BAND_A": 1,
      "FORMULA": "A <= 20",
      "OUTPUT": "outputs/low_elevation_raster.tif"
    },
    "input_files": [
      "outputs/kerala_dem_clipped.tif"
    ],
    "output_file": "outputs/low_elevation_raster.tif",
    "script_filename": "step_03_identify_low_elevation.py"
  },
  {
    "step_id": "step_04",
    "algorithm": "gdal:clipvectorbypolygon",
    "parameters": {
      "INPUT": "data/HydroRIVERS_v10_as.shp",
      "MASK": "outputs/kerala_boundary.shp"
    },
    "input_files": [
      "data/HydroRIVERS_v10_as.shp",
      "outputs/kerala_boundary.shp"
    ],
    "output_file": "outputs/kerala_rivers.shp",
    "script_filename": "step_04_clip_rivers.py"
  },
  {
    "step_id": "step_05",
    "algorithm": "native:reprojectlayer",
    "parameters": {
      "INPUT": "outputs/kerala_rivers.shp",
      "TARGET_CRS": "EPSG:3857"
    },
    "input_files": [
      "outputs/kerala_rivers.shp"
    ],
    "output_file": "outputs/kerala_rivers_3857.shp",
    "script_filename": "step_05_reproject_rivers.py"
  },
  {
    "step_id": "step_06",
    "algorithm": "native:buffer",
    "parameters": {
      "INPUT": "outputs/kerala_rivers_3857.shp",
      "DISTANCE": 1000,
      "SEGMENTS": 5,
      "END_CAP_STYLE": 0,
      "JOIN_STYLE": 0,
      "DISSOLVE": true
    },
    "input_files": [
      "outputs/kerala_rivers_3857.shp"
    ],
    "output_file": "outputs/kerala_river_buffer_3857.shp",
    "script_filename": "step_06_buffer_rivers.py"
  },
  {
    "step_id": "step_07",
    "algorithm": "native:reprojectlayer",
    "parameters": {
      "INPUT": "outputs/kerala_river_buffer_3857.shp",
      "TARGET_CRS": "EPSG:4326"
    },
    "input_files": [
      "outputs/kerala_river_buffer_3857.shp"
    ],
    "output_file": "outputs/kerala_river_buffer_4326.shp",
    "script_filename": "step_07_reproject_buffer_back.py"
  },
  {
    "step_id": "step_08",
    "algorithm": "gdal:rasterize",
    "parameters": {
      "INPUT": "outputs/kerala_river_buffer_4326.shp",
      "BURN": 1.0,
      "UNITS": 0,
      "NODATA": 0.0,
      "DATA_TYPE": 0,
      "EXTENT": "outputs/kerala_dem_clipped.tif",
      "WIDTH": "outputs/kerala_dem_clipped.tif",
      "HEIGHT": "outputs/kerala_dem_clipped.tif"
    },
    "input_files": [
      "outputs/kerala_river_buffer_4326.shp",
      "outputs/kerala_dem_clipped.tif"
    ],
    "output_file": "outputs/river_buffer_raster.tif",
    "script_filename": "step_08_rasterize_river_buffer.py"
  },
  {
    "step_id": "step_09",
    "algorithm": "gdal:rastercalculator",
    "parameters": {
      "INPUT_A": "outputs/low_elevation_raster.tif",
      "BAND_A": 1,
      "INPUT_B": "outputs/river_buffer_raster.tif",
      "BAND_B": 1,
      "FORMULA": "(A==1)*(B==1)",
      "OUTPUT": "outputs/flood_prone_raster.tif"
    },
    "input_files": [
      "outputs/low_elevation_raster.tif",
      "outputs/river_buffer_raster.tif"
    ],
    "output_file": "outputs/flood_prone_raster.tif",
    "script_filename": "step_09_combine_criteria.py"
  },
  {
    "step_id": "step_10",
    "algorithm": "gdal:polygonize",
    "parameters": {
      "INPUT": "outputs/flood_prone_raster.tif",
      "BAND": 1,
      "FIELD": "DN"
    },
    "input_files": [
      "outputs/flood_prone_raster.tif"
    ],
    "output_file": "outputs/flood_prone_polygons_raw.shp",
    "script_filename": "step_10_polygonize_flood_prone.py"
  },
  {
    "step_id": "step_11",
    "algorithm": "native:extractbyattribute",
    "parameters": {
      "INPUT": "outputs/flood_prone_polygons_raw.shp",
      "FIELD": "DN",
      "OPERATOR": 0,
      "VALUE": "1"
    },
    "input_files": [
      "outputs/flood_prone_polygons_raw.shp"
    ],
    "output_file": "outputs/flood_prone_polygons_filtered.shp",
    "script_filename": "step_11_filter_polygonized_areas.py"
  },
  {
    "step_id": "step_12",
    "algorithm": "native:clip",
    "parameters": {
      "INPUT": "outputs/flood_prone_polygons_filtered.shp",
      "OVERLAY": "outputs/kerala_boundary.shp"
    },
    "input_files": [
      "outputs/flood_prone_polygons_filtered.shp",
      "outputs/kerala_boundary.shp"
    ],
    "output_file": "outputs/flood_prone_areas.shp",
    "script_filename": "step_12_final_clip_to_boundary.py"
  }
]